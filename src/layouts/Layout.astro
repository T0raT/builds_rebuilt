<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
    <div class="svg-wrapper" data-js="outer-frame" style="opacity: 1;"> 
      <svg fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <mask id="mask">
            <rect id="outer-mask-bg" x="0" y="0" fill="white"></rect>
            <rect id="inner-mask-body" class="rect-radius" fill="black"></rect> 
          </mask> 
        </defs>
        <rect id="outer-rect-bg" class="rect-bg" x="0" y="0" fill="var(--color-bg)" mask="url(#mask)"></rect>
        <rect id="inner-rect-border" class="rect-radius" stroke-width="1" stroke="var(--color-border)" vector-effect="non-scaling-stroke"></rect> 
      </svg>
    </div>
		<slot />
	</body>
</html>

<script>
  const svgFrame = document.querySelector('[data-js="outer-frame"] svg');
  const outerRects = document.querySelectorAll("#outer-mask-bg, #outer-rect-bg");
  const innerRects = document.querySelectorAll("#inner-mask-body, #inner-rect-border");
  const GAP = 20;

  if (window) {
    updateSVGWrapper(); // Initial call

    window.addEventListener("resize", updateSVGWrapper);

  } else {
    throw new Error("Window does not exist...?")
  }
  
  function updateSVGWrapper() {
    const vh = window.innerHeight;
    const vw = window.innerWidth; 

    svgFrame?.setAttribute("width", `${vw}`);
    svgFrame?.setAttribute("height", `${vh}`);
    svgFrame?.setAttribute("viewBox", `0 0 ${vw} ${vh}`)

    outerRects.forEach(r => {
      r.setAttribute("width", `${vw}`);
      r.setAttribute("height", `${vh}`);
    });

    innerRects.forEach(r => {
      r.setAttribute("x", `${GAP}`);
      r.setAttribute("y", `${GAP}`);
      r.setAttribute("width", `${vw - 2 * GAP}`);
      r.setAttribute("height", `${vh - 2 * GAP}`);
    });
  }
</script>

<style is:global>
  :root {
    --color-white-1: #fff;
    --color-white-2: #f3f3ff;
    --color-white-3: #a4a4a4;
    --color-black-1: #000;
    --color-black-2: #101016;
    --color-black-3: #565656;

    --color-bg: var(--color-black-2);
    --color-text: var(--color-white-1);
    --color-border: var(--color-white-3);
  }

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

  html {
    background-color: black;
    color: white;
  }

  .rect-radius {
    rx: 12px;
  }

  .svg-wrapper {
    position: fixed;
    width: 100vw;
    height: 100svh;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 999;
  }
  .svg-wrapper svg{
    display: block;
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
  }
  .svg-wrapper rect {
    transform-origin: center;
  }
</style>
