---
import fl from "figlet";
import AnsiShadow from "figlet/fonts/ANSI Shadow";
fl.parseFont("AnsiShadow", AnsiShadow); // load font
const BU = fl.textSync("BU", { font: "AnsiShadow" }).trim();
const ILDS = fl.textSync("ILDS", { font: "AnsiShadow" }).trim();
---

<header id="logo-container">
  <pre style="color:red;">{BU}</pre>
  <pre style="color:var(--color-papaya-white);">{ILDS}</pre>
</header>
<style>
  #logo-container {
    position: fixed;
    top: 8px;
    left: 50%;
    transform: translatex(-50%);
    width: fit-content;
    white-space: nowrap;
    text-align: center;
    background-color: var(--color-bg);
    height: 44px;
    z-index: 9999;
  }

  #logo-container pre {
    font-family: "Courier New", monospace;
    font-size: 8px;
    line-height: 1;
    display: inline-block;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 767px) {
    #logo-container {
      top: 18px;
      left: 90px;
      transform: none;
      height: 85px;
    }
    #logo-container pre {
      font-size: 15px;
    }
  }
</style>
