---
import HamburgerIconSVG from "@assets/hamburger-menu.svg";
---

<div id="hamburger">
  <HamburgerIconSVG />
</div>

<script>
  /*
   * A data attribute is toggled when this icon is clicked,
   * simutaneously fires/dispatches a CustomEvent with data toggled boolean custom data.
   *
   * Components that needs to be animated listens for this CustomEvent,
   * in order to reveal MobileNavMenu.
   * */

  import { animate } from "animejs";

  //  const navEvent = new CustomEvent("navEvent");
  const hamburger = document.querySelector("#hamburger");

  hamburger?.addEventListener("click", () => {
    // Toggling an attribute returns true/false as return value
    const navStatus = document.body.toggleAttribute("data-nav-open");
    document.dispatchEvent(
      new CustomEvent("navEvent", {
        detail: navStatus,
      }),
    );
  });

  document.addEventListener("navEvent", (e) => {
    const navEvent = e as CustomEvent;
    if (navEvent.detail === true) {
      animate("#hamburger", {
        duration: 500,
        ease: "outElastic(1,2)",
        translateY: `120`,
      });
    } else {
      animate("#hamburger", {
        duration: 500,
        ease: "outElastic(1,2)",
        translateY: `0`,
      });
    }
  });
</script>

<style>
  div {
    position: fixed;
    width: 35px;
    height: 35px;
    right: 15px;
    top: 30px;
    border-bottom: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    background-color: var(--color-bg);
    z-index: 2000;
  }
  svg {
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  @media (min-width: 767px) {
    div {
      display: none;
    }
  }
</style>
