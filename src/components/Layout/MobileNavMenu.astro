<nav id="mobile-nav">
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/events">Events</a></li>
    <li><a href="/eboard">E-Board</a></li>
  </ul>
</nav>

<script>
  import { animate } from "animejs";
  const navMenu = document.getElementById("mobile-nav");
  if (!navMenu) throw new Error("mobile-nav does not exist somehow");

  document.addEventListener("navEvent", (e) => {
    const navEvent = e as CustomEvent;
    if (navEvent.detail === true) {
      navMenu.style.opacity = "1";
      navMenu.style.visibility = "visible";
    } else {
      navMenu.style.opacity = "0";
      navMenu.style.visibility = "hidden";
    }
  });
</script>

<style>
  nav {
    opacity: 0;
    z-index: 1999;
    position: fixed;
    width: 100%;
    height: 120px;
  }
  ul {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0;
    margin: 0;
    gap: 10px;

    text-align: start;
    list-style: none;
  }
</style>
